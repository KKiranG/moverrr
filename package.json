{
  "name": "moverrr",
  "version": "0.1.0",
  "private": true,
  "description": "MoveMate application repo and autonomous engineering control plane.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -print)",
    "webhook:replay": "node --import tsx scripts/replay-payment-webhook.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "scan:product-drift": "rg -n \"saved-search|saved search|join the waitlist|launch waitlist|direct booking|Browse-first|browse-first\" src README.md .agent-skills .claude --glob '!src/lib/data/alerts.ts' --glob '!**/saved-search-demand-review/**' --glob '!**/saved-searches/**' --glob '!**/CODEBASE-MAP.md' --glob '!**/command-catalog.md' --glob '!**/experiment-loop/SKILL.md' --glob '!**/capability-index.md'",
    "ops:labels": "node --import tsx scripts/setup-github-labels.ts",
    "ops:sync-backlog": "node --import tsx scripts/sync-backlog-from-github.ts",
    "ops:project": "node --import tsx scripts/setup-github-project.ts",
    "ops:sync-fields": "node --import tsx scripts/sync-project-fields.ts",
    "supabase:start": "supabase start",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:db:push": "supabase db push",
    "supabase:db:reset": "supabase db reset"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/render": "^1.4.0",
    "@sentry/nextjs": "^10.45.0",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/proxyquire": "^1.3.31",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "proxyquire": "^2.1.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}

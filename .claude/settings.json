{
  "permissions": {
    "allow": [
      "Bash(npm run check)",
      "Bash(npm run test*)",
      "Bash(npm run lint)",
      "Bash(npx tsc*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/validate-bash.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

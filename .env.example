# Public URLs and runtime labels. These values are safe to expose in the browser.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Required build / deploy variables. `next.config.js` validates these during
# production `npm run build`, using `config/required-production-env.json`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional product integrations.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@movemate.app

# Stripe Connect overrides. Leave blank to fall back to app URL defaults.
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/carrier/onboarding
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/carrier/onboarding

# Observability and web-push delivery.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@movemate.app

# Admin, cron, and smoke-test controls. Keep these server-side only.
ADMIN_EMAILS=
CRON_SECRET=
VERCEL_CRON_SECRET=
SMOKE_BOOTSTRAP_SECRET=

# Local-only toggles.
RUN_SUPABASE_INTEGRATION=0

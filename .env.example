# Public app URL for links, emails, OG metadata, robots.txt, and sitemap.xml.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Environment label used in Sentry and app health reporting.
NEXT_PUBLIC_APP_ENV=development

# Required production runtime envs.
# Supabase project URL and anon key for the client app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role for admin-only jobs, storage signing, and edge functions.
SUPABASE_SERVICE_ROLE_KEY=

# Optional Upstash Redis for production rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Maps Places + geocoding for route inputs and suburb matching.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Stripe checkout/auth flows and webhook processing.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/carrier/onboarding
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/carrier/onboarding

# Resend email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@moverrr.com.au

# Sentry client DSN plus release tag for deploy tracking.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_RELEASE=

# Web push keys for browser notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@moverrr.com.au

# Comma-separated admin emails for bootstrapping admin access.
ADMIN_EMAILS=

# Local QA smoke dataset bootstrap.
SMOKE_BOOTSTRAP_SECRET=

# E2E environment — copy to .env.e2e.local and fill in values.
# .env.e2e.local is gitignored; never commit real credentials.
#
# SAFETY CONTRACT:
#  - Supabase must point at a non-production project (dev/CI only).
#  - Stripe keys MUST start with sk_test_ / pk_test_ — live keys are blocked by e2e-preflight.
#  - Run `npm run verify:e2e:preflight` before running `npm run e2e`.
#  - Reset test data with `npm run e2e:reset` before the first run or after data drift.

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# --- Supabase (non-production dev project) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe test-mode keys only ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Set this after running: stripe listen --forward-to localhost:3000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# --- Maps: mocked locally; set E2E_MOCK_MAPS=false + real keys for real-maps tests ---
E2E_MOCK_MAPS=true
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_API_KEY=

# --- E2E seed user credentials (from supabase/seed.sql — do not change) ---
# These are deterministic local-only test credentials, not production accounts.
E2E_CUSTOMER_EMAIL=customer@example.com
E2E_CUSTOMER_PASSWORD=Password123!
E2E_CARRIER_EMAIL=carrier@example.com
E2E_CARRIER_PASSWORD=Password123!

# --- Optional: override base URL for preview E2E runs ---
# E2E_BASE_URL=https://<preview-url>

# --- Optional integrations (not needed for core E2E) ---
EMAIL_DELIVERY_MODE=log
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
